<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petrescue.petrescuesystem.mapper.ReportAuditLogMapper">

    <resultMap id="BaseResultMap" type="com.petrescue.petrescuesystem.entity.ReportAuditLog">
        <id column="log_id" property="logId" jdbcType="BIGINT"/>
        <result column="report_id" property="reportId" jdbcType="BIGINT"/>
        <result column="operator_user_id" property="operatorUserId" jdbcType="BIGINT"/>
        <result column="action" property="action" jdbcType="INTEGER"/>
        <result column="notes" property="notes" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByReportId" resultMap="BaseResultMap">
        SELECT * FROM report_audit_log WHERE report_id = #{reportId} ORDER BY created_at DESC
    </select>

    <select id="selectByOperatorUserId" resultMap="BaseResultMap">
        SELECT * FROM report_audit_log WHERE operator_user_id = #{operatorUserId} ORDER BY created_at DESC
    </select>

    <select id="selectByAction" resultMap="BaseResultMap">
        SELECT * FROM report_audit_log WHERE action = #{action} ORDER BY created_at DESC
    </select>

    <select id="countByReportId" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM report_audit_log WHERE report_id = #{reportId}
    </select>

</mapper>