<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petrescue.petrescuesystem.mapper.ReportMapper">

    <resultMap id="BaseResultMap" type="com.petrescue.petrescuesystem.entity.Report">
        <id column="report_id" property="reportId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="target_type" property="targetType" jdbcType="INTEGER"/>
        <result column="target_id" property="targetId" jdbcType="BIGINT"/>
        <result column="reason" property="reason" jdbcType="VARCHAR"/>
        <result column="detail" property="detail" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="INTEGER"/>
        <result column="handler_user_id" property="handlerUserId" jdbcType="BIGINT"/>
        <result column="handle_notes" property="handleNotes" jdbcType="VARCHAR"/>
        <result column="handled_at" property="handledAt" jdbcType="TIMESTAMP"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM report WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="selectByTargetType" resultMap="BaseResultMap">
        SELECT * FROM report WHERE target_type = #{targetType} ORDER BY created_at DESC
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM report WHERE status = #{status} ORDER BY created_at DESC
    </select>

    <select id="selectReportPage" resultMap="BaseResultMap">
        SELECT * FROM report WHERE 1=1
        <if test="targetType != null">AND target_type = #{targetType}</if>
        <if test="status != null">AND status = #{status}</if>
        ORDER BY created_at DESC
    </select>

    <select id="countByUserId" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM report WHERE user_id = #{userId}
    </select>

    <select id="countByStatus" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM report WHERE status = #{status}
    </select>

    <update id="updateStatus">
        UPDATE report SET status = #{status}, handler_user_id = #{handlerUserId}, handle_notes = #{handleNotes}, handled_at = NOW() WHERE report_id = #{reportId}
    </update>

    <select id="selectPendingReports" resultMap="BaseResultMap">
        SELECT * FROM report WHERE status = 0 ORDER BY created_at ASC
    </select>

    <select id="selectRecentReports" resultMap="BaseResultMap">
        SELECT * FROM report ORDER BY created_at DESC LIMIT #{limit}
    </select>

</mapper>